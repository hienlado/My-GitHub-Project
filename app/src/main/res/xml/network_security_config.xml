<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cho phép tất cả HTTPS traffic (bao gồm tile servers) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
    <!-- Cho phép cleartext cho các tile server cần HTTP -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">tile.opentopomap.org</domain>
        <domain includeSubdomains="true">mt0.google.com</domain>
        <domain includeSubdomains="true">mt1.google.com</domain>
        <domain includeSubdomains="true">mt2.google.com</domain>
        <domain includeSubdomains="true">mt3.google.com</domain>
        <domain includeSubdomains="true">server.arcgisonline.com</domain>
        <domain includeSubdomains="true">basemaps.cartocdn.com</domain>
        <domain includeSubdomains="true">tile.openstreetmap.org</domain>
    </domain-config>
</network-security-config>
